{
  "name": "Gemini Dynamic Image Generator",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inkblot-icon",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=AIzaSyCAz-xuvLIkhrMMVOITPjIOG8-2ERQd0AE",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "sendQuery": false,
        "sendBody": true,
        "bodyParametersUiExpression": {
          "parameters": [
            {
              "name": "contents",
              "value": "[{\"parts\":[{\"text\":\"{{ $json.body.prompt }}\"}]}]"
            },
            {
              "name": "generationConfig",
              "value": "{\"responseMimeType\":\"image/png\"}"
            }
          ]
        },
        "options": {}
      },
      "id": "gemini_api",
      "name": "Gemini API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "fileName": "=/tmp/inkline_bg_{{ Date.now() }}.png",
        "fileContent": "={{ Buffer.from($response.body.candidates[0].content.parts[0].inline_data.data, 'base64') }}",
        "options": {}
      },
      "id": "write_file",
      "name": "Write Binary File",
      "type": "n8n-nodes-base.writeBinaryFile",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "respondWithOptions": {
          "responseBody": "{\"image_path\":\"{{ $node['write_file'].json.file_path }}\"}"
        },
        "options": {}
      },
      "id": "http_response",
      "name": "HTTP Response",
      "type": "n8n-nodes-base.httpRespond",
      "typeVersion": 1,
      "position": [700, 300]
    }
  ],
  "connections": {
    "webhook": {
      "main": [
        [
          {
            "node": "gemini_api",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "gemini_api": {
      "main": [
        [
          {
            "node": "write_file",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "write_file": {
      "main": [
        [
          {
            "node": "http_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
