{
  "name": "Gemini Dynamic Image Generator",
  "active": true,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inkblot-icon",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=AIzaSyCAz-xuvLIkhrMMVOITPjIOG8-2ERQd0AE",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "sendQuery": false,
        "sendBody": true,
        "bodyParametersUiExpression": {
          "parameters": [
            {
              "name": "contents",
              "value": "[{\"parts\":[{\"text\":\"{{ $json.body.prompt }}\"}]}]"
            },
            {
              "name": "generationConfig",
              "value": "{\"responseMimeType\":\"image/png\"}"
            }
          ]
        },
        "options": {}
      },
      "id": "gemini_api",
      "name": "Gemini API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst base64Data = item.json.candidates[0].content.parts[0].inlineData.data;\nconst filePath = `/tmp/inkline_bg_${Date.now()}.png`;\nconst fs = require('fs');\nconst buf = Buffer.from(base64Data, 'base64');\nfs.writeFileSync(filePath, buf);\nreturn [{ json: { file_path: filePath, bytes: buf.length } }];"
      },
      "id": "write_file",
      "name": "Write File & Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ image_path: $input.first().json.file_path }) }}",
        "options": {}
      },
      "id": "http_response",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [700, 300]
    }
  ],
  "connections": {
    "webhook": {
      "main": [
        [
          {
            "node": "gemini_api",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "gemini_api": {
      "main": [
        [
          {
            "node": "write_file",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "write_file": {
      "main": [
        [
          {
            "node": "http_response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
